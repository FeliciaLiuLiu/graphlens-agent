{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["nodes", "edges", "visual_signals", "extraction_uncertainties"],
  "additionalProperties": false,
  "properties": {
    "case_id": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "confidence"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "visible_color": {"type": ["string", "null"]},
          "role_hint_from_label": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "direction_confidence", "amount_confidence"],
        "additionalProperties": false,
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "amount_text": {"type": ["string", "null"]},
          "amount_value": {"type": ["number", "null"]},
          "currency": {"type": ["string", "null"]},
          "visible_color": {"type": ["string", "null"]},
          "direction_confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "amount_confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "visual_signals": {"type": "object"},
    "extraction_uncertainties": {"type": "array", "items": {"type": "string"}}
  }
}
