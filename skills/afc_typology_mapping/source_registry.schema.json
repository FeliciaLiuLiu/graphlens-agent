{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/afc-network-narrative/skills/afc_typology_mapping/source_registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["sources"],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
