{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graphlens-agent.local/schemas/graph.schema.json",
  "title": "GraphLens Graph Document",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "nodes", "edges"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "source_type": { "type": "string" },
        "source_name": { "type": "string" },
        "directed": { "type": "boolean", "default": true },
        "extraction_method": { "type": "string" },
        "extraction_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "created_at": { "type": "string" },
        "domain": { "type": "string" }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "default": "entity" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "position": { "$ref": "#/$defs/position" },
        "attributes": { "type": "object" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "directed": { "type": "boolean" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "attributes": { "type": "object" }
      }
    }
  }
}
